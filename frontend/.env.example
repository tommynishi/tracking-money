# 環境変数の一覧・用途・公開範囲は docs/architecture.md 9.2 を正とします。
# このファイルはプレースホルダのみ。実値は frontend/.env.local に設定し、コミットしないこと。
# NEXT_PUBLIC_ が付く変数のみクライアントへ公開される。それ以外はサーバー専用。

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Auth.js（LINE Login）
AUTH_SECRET=generate-with-npx-auth-secret
LINE_CHANNEL_ID=your-line-login-channel-id
LINE_CHANNEL_SECRET=your-line-login-channel-secret

# LINE Messaging API（通知・Loginとは別チャネル・CON-04）
LINE_MESSAGING_CHANNEL_ACCESS_TOKEN=your-messaging-channel-access-token

# OpenAI（AI分析 / Vision OCR）
OPENAI_API_KEY=sk-your-openai-api-key

# Google Drive（アプリ管理のサービスアカウント・CON-05）
# サービスアカウント単体は保存容量を持たないため、人間の Google アカウントで
# フォルダを作成しサービスアカウント（client_email）に編集者権限で共有し、
# そのフォルダIDを GOOGLE_DRIVE_ROOT_FOLDER_ID に設定する。
GOOGLE_SERVICE_ACCOUNT_KEY=your-service-account-json
GOOGLE_DRIVE_ROOT_FOLDER_ID=your-shared-folder-id

# Vercel Cron 保護
CRON_SECRET=your-cron-secret
